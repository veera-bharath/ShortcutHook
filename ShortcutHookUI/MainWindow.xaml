<Window x:Class="ShortcutHookUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shortcut Hook" Width="700" Height="700" Icon="pack://application:,,,/Assets/ShortcutHook.ico"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip"
        MinWidth="580" MinHeight="540" Background="#111111" FontFamily="Segoe UI">
    <Window.Resources>

        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.82"/></Trigger>
                            <Trigger Property="IsPressed"   Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.65"/></Trigger>
                            <Trigger Property="IsEnabled"   Value="False"><Setter TargetName="Bd" Property="Opacity" Value="0.35"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Foreground" Value="#BBBBBB"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2E2E2E"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1F1F1F"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3E3E3E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkTB" TargetType="TextBox">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="CaretBrush" Value="#E8E8E8"/>
            <Setter Property="SelectionBrush" Value="#5B9CF6"/>
            <Setter Property="BorderBrush" Value="#303030"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="8,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#5B9CF6"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Toggle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#DCDCDC"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Grid Width="44" Height="24">
                                <Border x:Name="Track" CornerRadius="12" Background="#2E2E2E" BorderBrush="#3A3A3A" BorderThickness="1"/>
                                <Ellipse x:Name="Thumb" Width="18" Height="18" Fill="#666666" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="2,0,0,0"/>
                            </Grid>
                            <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#5B9CF6"/>
                                <Setter TargetName="Track" Property="BorderBrush" Value="#5B9CF6"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="#FFFFFF"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#1C1C1C"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="DarkRadio" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid Width="18" Height="18">
                            <Ellipse x:Name="Outer" Stroke="#555555" StrokeThickness="1.5" Fill="Transparent"/>
                            <Ellipse x:Name="Inner" Width="9" Height="9" Fill="#5B9CF6" Opacity="0"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Outer" Property="Stroke" Value="#5B9CF6"/>
                                <Setter TargetName="Inner" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Outer" Property="Stroke" Value="#777777"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsOptionCard" TargetType="Border">
            <Setter Property="Background" Value="#1F1F1F"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#272727"/>
                    <Setter Property="BorderBrush" Value="#454545"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkCBItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground"  Value="#E8E8E8"/>
            <Setter Property="Background"  Value="#252525"/>
            <Setter Property="Padding"     Value="10,6"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#333333"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1D3A5E"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsHighlighted" Value="True"/>
                                    <Condition Property="IsSelected"    Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#2A4F7A"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern dark scrollbar -->
        <Style x:Key="ScrollBarPageBtn" TargetType="RepeatButton">
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarThumb" TargetType="Thumb">
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThBd" CornerRadius="4" Background="#3A3A3A" Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThBd" Property="Background" Value="#5A5A5A"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThBd" Property="Background" Value="#6E6E6E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="10"/>
                    <Setter Property="MinWidth" Value="10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent">
                                    <Track x:Name="PART_Track" IsDirectionReversed="True">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageBtn}" Command="ScrollBar.PageUpCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumb}" MinHeight="30"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageBtn}" Command="ScrollBar.PageDownCommand"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="10"/>
                    <Setter Property="MinHeight" Value="10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent">
                                    <Track x:Name="PART_Track">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageBtn}" Command="ScrollBar.PageLeftCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumb}" MinWidth="30"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageBtn}" Command="ScrollBar.PageRightCommand"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkCB" TargetType="ComboBox">
            <Setter Property="Foreground"        Value="#E8E8E8"/>
            <Setter Property="Background"        Value="#252525"/>
            <Setter Property="BorderBrush"       Value="#353535"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="FontFamily"        Value="Segoe UI"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkCBItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="Root">
                            <ToggleButton x:Name="TogBtn" Focusable="False" ClickMode="Press"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="TBd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6">
                                            <Path x:Name="Arrow" HorizontalAlignment="Right"
                                                  VerticalAlignment="Center" Margin="0,0,9,0"
                                                  Data="M0,0 L4.5,5 L9,0" Stroke="#777777"
                                                  StrokeThickness="1.5" Fill="Transparent"
                                                  StrokeLineJoin="Round" StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="TBd" Property="Background"  Value="#2E2E2E"/>
                                                <Setter TargetName="TBd" Property="BorderBrush" Value="#555555"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="TBd" Property="BorderBrush" Value="#5B9CF6"/>
                                                <Setter TargetName="Arrow" Property="Stroke"    Value="#5B9CF6"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              Margin="10,0,26,0"
                                              HorizontalAlignment="Left" VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              IsHitTestVisible="False"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                            <Popup x:Name="PART_Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Fade">
                                <Border x:Name="DropBorder"
                                        MinWidth="{Binding ActualWidth, ElementName=Root}"
                                        MaxHeight="280"
                                        Background="#252525" BorderBrush="#454545" BorderThickness="1"
                                        CornerRadius="0,0,6,6">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Opacity="0.6" BlurRadius="10" ShadowDepth="3"/>
                                    </Border.Effect>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" SnapsToDevicePixels="True">
                                        <ItemsPresenter SnapsToDevicePixels="True"
                                                        KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
    <Grid x:Name="MainAppRoot" Margin="20,18,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <Button DockPanel.Dock="Right" Content="&#9881;" Style="{StaticResource BtnGhost}"
                    Height="28" Width="36" Padding="0" FontSize="15" VerticalAlignment="Top"
                    Click="SettingsBtn_Click"/>
            <Button x:Name="ProfileSwitcherBtn" DockPanel.Dock="Right" Style="{StaticResource BtnGhost}"
                    Height="28" Padding="10,0" VerticalAlignment="Top" Margin="0,0,8,0"
                    Click="ProfileSwitcherBtn_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="ProfileSwitcherLabel" Text="Default" Foreground="#E8E8E8"
                               FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="&#9662;" Foreground="#777777" FontSize="9"
                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>
            </Button>
            <Popup x:Name="ProfileSwitcherPopup" DockPanel.Dock="Right"
                   PlacementTarget="{Binding ElementName=ProfileSwitcherBtn}"
                   Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                <Border Background="#252525" BorderBrush="#454545" BorderThickness="1" CornerRadius="6"
                        MinWidth="170" Padding="4">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.6" BlurRadius="10" ShadowDepth="3"/>
                    </Border.Effect>
                    <StackPanel x:Name="ProfileSwitcherList"/>
                </Border>
            </Popup>
            <StackPanel>
                <TextBlock Text="Shortcut Hook" Foreground="#EFEFEF" FontSize="20" FontWeight="Bold"/>
                <TextBlock Text="Map mouse gestures and keyboard combos to shortcuts"
                           Foreground="#555555" FontSize="12" Margin="0,4,0,0"/>
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1" x:Name="UpdateBanner" Style="{StaticResource Card}"
                Background="#2A2410" BorderBrush="#4A3F1A" Margin="0,0,0,12" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="UpdateBannerText" VerticalAlignment="Center"
                           Foreground="#E8C25C" FontSize="13" TextWrapping="Wrap"/>
                <TextBlock Grid.Column="1" Text="Download" Cursor="Hand" VerticalAlignment="Center"
                           Foreground="#E8C25C" FontSize="13" FontWeight="SemiBold" TextDecorations="Underline"
                           Margin="12,0,12,0" MouseLeftButtonDown="UpdateDownload_Click"/>
                <Button Grid.Column="2" Content="&#10005;" Style="{StaticResource BtnGhost}"
                        Width="28" Height="24" Padding="0" FontSize="11" VerticalAlignment="Center"
                        Click="UpdateDismiss_Click"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="HOOK STATUS" Style="{StaticResource SectionLabel}" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="StatusDot" Width="9" Height="9" Fill="#E85C5C" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="StatusText" Text="Stopped" Foreground="#CCCCCC" FontSize="14" VerticalAlignment="Center"/>
                        <Border x:Name="PausedBadge" Background="#3A3210" CornerRadius="4" Padding="6,2"
                                Margin="10,0,0,0" VerticalAlignment="Center" Visibility="Collapsed">
                            <TextBlock Text="⏸ Paused" Foreground="#E8C25C" FontSize="12" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
                <Button x:Name="HookBtn" Grid.Column="1" Content="Start" Background="#3DBA7B"
                        Style="{StaticResource BtnPrimary}" Width="82" Height="34" Padding="0"
                        Click="HookBtn_Click"/>
            </Grid>
        </Border>

        <Border Grid.Row="4" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid>
                    <TextBox x:Name="SearchBox" Style="{StaticResource DarkTB}" Height="32"
                             Padding="10,0" FontFamily="Segoe UI" FontSize="12"
                             TextChanged="SearchBox_TextChanged"/>
                    <TextBlock x:Name="SearchPlaceholder" Text="Search bindings..."
                               Foreground="#3A3A3A" FontSize="12" FontFamily="Segoe UI"
                               VerticalAlignment="Center" Margin="18,0,0,0"
                               IsHitTestVisible="False"/>
                </Grid>
                <Button Grid.Column="1" x:Name="SearchClearBtn"
                        Style="{StaticResource BtnGhost}" Width="30" Height="30"
                        Padding="0" Margin="6,0,0,0" Visibility="Collapsed"
                        ToolTip="Clear search"
                        Click="SearchClearBtn_Click">
                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
                <Button Grid.Column="2" x:Name="ImportBindingBtn"
                        Style="{StaticResource BtnGhost}" Height="30" Padding="10,0"
                        Margin="6,0,0,0"
                        ToolTip="Import a binding from clipboard JSON"
                        Click="ImportBindingBtn_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE77F;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="Import" FontFamily="Segoe UI" FontSize="11"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="5" VerticalScrollBarVisibility="Auto" Margin="0,0,-4,0">
            <StackPanel Margin="0,0,4,0">

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid x:Name="MouseHeader" Cursor="Hand" Background="Transparent"
                              MouseLeftButtonDown="MouseHeader_Click">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="MOUSE SHORTCUTS" Style="{StaticResource SectionLabel}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="MouseChevron" Grid.Column="1" Text="▾"
                                       Foreground="#555555" FontSize="11" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel x:Name="MouseBody" Margin="0,10,0,0">
                            <StackPanel x:Name="MouseStack"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid x:Name="KbdHeader" Cursor="Hand" Background="Transparent"
                              MouseLeftButtonDown="KbdHeader_Click">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="KEYBOARD SHORTCUTS" Style="{StaticResource SectionLabel}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="KbdChevron" Grid.Column="1" Text="›"
                                       Foreground="#555555" FontSize="11" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel x:Name="KbdBody" Visibility="Collapsed" Margin="0,8,0,0">
                            <DockPanel Margin="0,0,0,8">
                                <Button x:Name="AddKbdBtn" DockPanel.Dock="Right" Content="+ New trigger"
                                        Style="{StaticResource BtnGhost}" Height="24" Width="90" Padding="0"
                                        HorizontalAlignment="Right" Click="AddKbdBtn_Click"/>
                            </DockPanel>
                            <StackPanel x:Name="KbdStack"/>
                            <TextBlock Margin="0,8,0,0"
                                       Text="Each card is one trigger. Use '+ App' to add app-specific variants that override the global action. Esc cancels capture."
                                       Foreground="#3A3A3A" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="3" Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="STARTUP" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>
                    <TextBlock Text="Launch automatically on Windows login" Foreground="#DCDCDC" FontSize="13"/>
                </StackPanel>
                <CheckBox x:Name="StartupToggle" Grid.Column="1" Style="{StaticResource Toggle}" VerticalAlignment="Center"
                          Click="StartupToggle_Click"/>
            </Grid>
        </Border>

        <Button Grid.Row="6" x:Name="SaveBtn" Content="Save Changes"
                Background="#5B9CF6" Style="{StaticResource BtnPrimary}" Height="42" Padding="0" FontSize="14" Margin="0,4,0,0"
                Click="SaveBtn_Click"/>
        <TextBlock Grid.Row="7" x:Name="FeedbackMsg" Foreground="#3DBA7B" FontSize="12"
                   HorizontalAlignment="Center" Margin="0,10,0,0" TextWrapping="Wrap" TextAlignment="Center" Visibility="Collapsed"/>
    </Grid>
        <Border x:Name="SetupRoot" Background="#111111" Visibility="Collapsed">
            <Grid Margin="28,24,28,24">
                <Border Style="{StaticResource Card}" MaxWidth="620" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="24,22">
                    <StackPanel>
                        <TextBlock Text="First-Time Setup" Foreground="#EFEFEF" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="Complete these steps once. After setup, ShortcutHook will open straight into the main app."
                                   Foreground="#777777" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"/>

                        <Border Background="#171717" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="10" Margin="0,20,0,0" Padding="16,14">
                            <StackPanel>
                                <TextBlock Text="1. Install" Foreground="#F1F1F1" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Choose where to install the app. The daemon script is always placed at a fixed path."
                                           Foreground="#777777" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="52"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="App:" Foreground="#777777" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="SetupAppFolderText" Text=""
                                               Foreground="#5B9CF6" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Script:" Foreground="#777777" FontSize="12" VerticalAlignment="Center" Margin="0,5,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="SetupScriptFolderText" Text="C:\Tools\ShortcutHook"
                                               Foreground="#555555" FontSize="12" VerticalAlignment="Center" Margin="0,5,0,0"/>
                                </Grid>
                                <TextBlock x:Name="SetupInstallStatusText" Text="Not installed yet."
                                           Foreground="#BBBBBB" FontSize="12" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                    <Button x:Name="SetupInstallBtn" Content="Choose App Folder and Install"
                                            Background="#5B9CF6" Style="{StaticResource BtnPrimary}" Width="210" Height="36" Padding="0"
                                            Click="InstallBtn_Click"/>
                                    <Button x:Name="SetupOpenFolderBtn" Content="Open Script Folder"
                                            Style="{StaticResource BtnGhost}" Width="130" Height="36" Padding="0" Margin="10,0,0,0"
                                            Click="OpenInstallBtn_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="#171717" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="10" Margin="0,12,0,0" Padding="16,14">
                            <StackPanel>
                                <TextBlock Text="2. Add Start Menu Shortcut" Foreground="#F1F1F1" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Optional. This adds ShortcutHook to Start Menu so it behaves like a regular installed app."
                                           Foreground="#777777" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                <CheckBox x:Name="SetupStartMenuCheckbox" Content="Create Start Menu shortcut" Style="{StaticResource Toggle}" Margin="0,12,0,0" IsChecked="True"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#171717" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="10" Margin="0,12,0,0" Padding="16,14">
                            <StackPanel>
                                <TextBlock Text="3. Create Desktop Shortcut" Foreground="#F1F1F1" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Optional. This places a ShortcutHook shortcut on the desktop."
                                           Foreground="#777777" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                <CheckBox x:Name="SetupDesktopCheckbox" Content="Create desktop shortcut" Style="{StaticResource Toggle}" Margin="0,12,0,0" IsChecked="True"/>
                            </StackPanel>
                        </Border>

                        <Button x:Name="CompleteSetupBtn" Content="Finish Setup"
                                Background="#3DBA7B" Style="{StaticResource BtnPrimary}" Height="42" Padding="0" FontSize="14"
                                Margin="0,18,0,0" IsEnabled="False" Click="CompleteSetupBtn_Click"/>
                        <TextBlock x:Name="SetupHintText" Text="Install the runtime first to continue."
                                   Foreground="#777777" FontSize="12" Margin="0,10,0,0" TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="SettingsRoot" Background="#CC000000" Visibility="Collapsed"
                MouseDown="SettingsRoot_MouseDown">
            <Border Background="#171717" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="10"
                    Width="380" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Padding="20" MouseDown="SettingsCard_MouseDown">
                <StackPanel>

                    <StackPanel x:Name="SettingsMenuView">
                        <TextBlock Text="Settings" Foreground="#EFEFEF" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

                        <Border Style="{StaticResource SettingsOptionCard}" MouseLeftButtonDown="ManageProfilesOption_Click">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Manage Profiles" Foreground="#EFEFEF" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="Create, rename, and switch between profiles" Foreground="#777777" FontSize="11" Margin="0,3,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="&#8250;" Foreground="#555555" FontSize="18" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource SettingsOptionCard}" Margin="0,8,0,0" MouseLeftButtonDown="AboutOption_Click">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="About" Foreground="#EFEFEF" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="Version, author, and project links" Foreground="#777777" FontSize="11" Margin="0,3,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="&#8250;" Foreground="#555555" FontSize="18" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="SettingsProfilesView" Visibility="Collapsed">
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Profiles" Foreground="#EFEFEF" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Button x:Name="AddProfileBtn" DockPanel.Dock="Right" Content="+ Add Profile"
                                    Style="{StaticResource BtnGhost}" HorizontalAlignment="Right"
                                    Height="28" Padding="12,0" Click="AddProfileBtn_Click"/>
                        </DockPanel>
                        <TextBlock Text="Click a profile to select it for export." Foreground="#777777" FontSize="11" Margin="0,0,0,10"/>
                        <StackPanel x:Name="ProfileListStack"/>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button x:Name="ExportProfileBtn" Content="Export Selected" Style="{StaticResource BtnGhost}"
                                    Height="28" Padding="12,0" Click="ExportProfileBtn_Click"/>
                            <Button x:Name="ImportProfileBtn" Content="Import" Style="{StaticResource BtnGhost}"
                                    Height="28" Padding="12,0" Margin="8,0,0,0" Click="ImportProfileBtn_Click"/>
                        </StackPanel>
                        <Button Content="Back" Style="{StaticResource BtnGhost}" Height="34" Width="90"
                                HorizontalAlignment="Left" Margin="0,12,0,0" Click="SettingsBack_Click"/>
                    </StackPanel>

                    <StackPanel x:Name="SettingsProfileFormView" Visibility="Collapsed">
                        <TextBlock x:Name="ProfileFormTitle" Text="Add Profile" Foreground="#EFEFEF" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>
                        <TextBox x:Name="ProfileNameBox" Style="{StaticResource DarkTB}" Height="34" Padding="10,0" MaxLength="32"/>
                        <TextBlock x:Name="ProfileFormError" Foreground="#E85C5C" FontSize="11" Margin="0,8,0,0"
                                   TextWrapping="Wrap" Visibility="Collapsed"/>
                        <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                            <Button x:Name="ProfileFormConfirmBtn" Content="Create" Background="#5B9CF6"
                                    Style="{StaticResource BtnPrimary}" Height="36" Width="100" Padding="0"
                                    Click="ProfileFormConfirm_Click"/>
                            <Button Content="Cancel" Style="{StaticResource BtnGhost}" Height="36" Width="90" Padding="0"
                                    Margin="10,0,0,0" Click="ProfileFormCancel_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel x:Name="SettingsProfileDeleteView" Visibility="Collapsed">
                        <TextBlock Text="Delete Profile" Foreground="#EFEFEF" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
                        <TextBlock x:Name="ProfileDeleteMsg" Foreground="#CCCCCC" FontSize="13" TextWrapping="Wrap"/>
                        <TextBlock x:Name="ProfileDeleteError" Foreground="#E85C5C" FontSize="11" Margin="0,10,0,0"
                                   TextWrapping="Wrap" Visibility="Collapsed"/>
                        <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                            <Button x:Name="ProfileDeleteConfirmBtn" Content="Delete" Background="#E85C5C"
                                    Style="{StaticResource BtnPrimary}" Height="36" Width="100" Padding="0"
                                    Click="ProfileDeleteConfirm_Click"/>
                            <Button Content="Cancel" Style="{StaticResource BtnGhost}" Height="36" Width="90" Padding="0"
                                    Margin="10,0,0,0" Click="ProfileDeleteCancel_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel x:Name="SettingsAboutView" Visibility="Collapsed">
                        <Image Source="pack://application:,,,/Assets/ShortcutHook.png"
                               Width="48" Height="48" HorizontalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="ShortcutHook" Foreground="#EFEFEF" FontSize="20"
                                   FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        <TextBlock x:Name="SettingsVersionText" Foreground="#555555" FontSize="12"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                            <TextBlock Text="by " Foreground="#666666" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="Veera Bharath" Foreground="#AAAAAA" FontSize="12"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Style="{StaticResource BtnGhost}" Height="36" Padding="14,0"
                                HorizontalAlignment="Center" Margin="0,14,0,0"
                                Click="SettingsGitHubBtn_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Viewbox Width="16" Height="16">
                                    <Path Fill="#CCCCCC" Data="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18
                                          6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703
                                          -2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466
                                          -.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032
                                          .892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338
                                          -2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688
                                          -.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026
                                          A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337
                                          c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651
                                          .64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942
                                          .359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747
                                          0 .268.18.58.688.482A10.019 10.019 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
                                </Viewbox>
                                <TextBlock Text="GitHub" Foreground="#CCCCCC" FontSize="13"
                                           Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Content="Back" Style="{StaticResource BtnGhost}" Height="34" Width="90"
                                HorizontalAlignment="Left" Margin="0,18,0,0" Click="SettingsBack_Click"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
