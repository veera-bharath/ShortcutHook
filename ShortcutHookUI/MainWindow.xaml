<Window x:Class="ShortcutHookUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ShortcutHookUI.ViewModels"
        xmlns:local="clr-namespace:ShortcutHookUI"
        Title="Shortcut Hook" Width="900" Height="700" Icon="pack://application:,,,/Assets/ShortcutHook.ico"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip"
        MinWidth="680" MinHeight="520" Background="#111111" FontFamily="Segoe UI">
    <Window.Resources>

        <!-- ── Color tokens ── -->
        <SolidColorBrush x:Key="ColorPrimary"        Color="#5B9CF6"/>
        <SolidColorBrush x:Key="ColorSuccess"        Color="#4CAF50"/>
        <SolidColorBrush x:Key="ColorDanger"         Color="#E53935"/>
        <SolidColorBrush x:Key="ColorWarning"        Color="#FFC107"/>
        <SolidColorBrush x:Key="ColorSecondary"      Color="#888888"/>
        <SolidColorBrush x:Key="ColorTextPrimary"    Color="#EFEFEF"/>
        <SolidColorBrush x:Key="ColorTextSecondary"  Color="#CCCCCC"/>
        <SolidColorBrush x:Key="ColorTextDim"        Color="#888888"/>
        <SolidColorBrush x:Key="ColorTextMuted"      Color="#666666"/>
        <SolidColorBrush x:Key="ColorSurface"        Color="#1C1C1C"/>
        <SolidColorBrush x:Key="ColorSurfaceAlt"     Color="#171717"/>
        <SolidColorBrush x:Key="ColorBorder"         Color="#2A2A2A"/>
        <SolidColorBrush x:Key="ColorBorderSubtle"   Color="#222222"/>

        <!-- Value Converters -->
        <vm:ActionToVisibilityConverter x:Key="ActionToVisibilityConverter"/>
        <vm:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <vm:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <vm:RecordModeTextConverter x:Key="RecordModeTextConverter"/>

        <Style x:Key="BtnTab" TargetType="Button">
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="active">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#5B9CF6"/>
                                <Setter Property="Foreground" Value="#EFEFEF"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="Tag" Value="active"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#1A1A1A"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#161616"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.82"/></Trigger>
                            <Trigger Property="IsPressed"   Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.65"/></Trigger>
                            <Trigger Property="IsEnabled"   Value="False"><Setter TargetName="Bd" Property="Opacity" Value="0.35"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Foreground" Value="#BBBBBB"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2E2E2E"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1F1F1F"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3E3E3E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnStop" TargetType="Button">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E53935"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#E53935"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkTB" TargetType="TextBox">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="CaretBrush" Value="#E8E8E8"/>
            <Setter Property="SelectionBrush" Value="#5B9CF6"/>
            <Setter Property="BorderBrush" Value="#303030"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="8,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#5B9CF6"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Toggle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#DCDCDC"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Grid Width="44" Height="24">
                                <Border x:Name="Track" CornerRadius="12" BorderThickness="1">
                                    <Border.Background>
                                        <SolidColorBrush x:Name="TrackBrush" Color="#2E2E2E"/>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <SolidColorBrush x:Name="TrackBorderBrush" Color="#3A3A3A"/>
                                    </Border.BorderBrush>
                                </Border>
                                <Ellipse x:Name="Thumb" Width="18" Height="18"
                                         HorizontalAlignment="Left" VerticalAlignment="Center" Margin="3,0,0,0">
                                    <Ellipse.Fill>
                                        <SolidColorBrush x:Name="ThumbBrush" Color="#666666"/>
                                    </Ellipse.Fill>
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform x:Name="ThumbTranslate" X="0"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Grid>
                            <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             To="20" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ColorAnimation Storyboard.TargetName="TrackBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#5B9CF6" Duration="0:0:0.15"/>
                                            <ColorAnimation Storyboard.TargetName="TrackBorderBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#5B9CF6" Duration="0:0:0.15"/>
                                            <ColorAnimation Storyboard.TargetName="ThumbBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#FFFFFF" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             To="0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ColorAnimation Storyboard.TargetName="TrackBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#2E2E2E" Duration="0:0:0.15"/>
                                            <ColorAnimation Storyboard.TargetName="TrackBorderBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#3A3A3A" Duration="0:0:0.15"/>
                                            <ColorAnimation Storyboard.TargetName="ThumbBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#666666" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#1C1C1C"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ColorTextMuted}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="DarkRadio" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid Width="18" Height="18">
                            <Ellipse x:Name="Outer" Stroke="#555555" StrokeThickness="1.5" Fill="Transparent"/>
                            <Ellipse x:Name="Inner" Width="9" Height="9" Fill="#5B9CF6" Opacity="0"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Outer" Property="Stroke" Value="#5B9CF6"/>
                                <Setter TargetName="Inner" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Outer" Property="Stroke" Value="#777777"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsOptionCard" TargetType="Border">
            <Setter Property="Background" Value="#1F1F1F"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#272727"/>
                    <Setter Property="BorderBrush" Value="#454545"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsNavItem" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,9"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E1E1E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkCBItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground"  Value="#E8E8E8"/>
            <Setter Property="Background"  Value="#252525"/>
            <Setter Property="Padding"     Value="10,6"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#333333"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1D3A5E"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsHighlighted" Value="True"/>
                                    <Condition Property="IsSelected"    Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#2A4F7A"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Focus ring used by interactive controls -->
        <Style x:Key="FocusVisual">
            <Setter Property="Control.Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Rectangle Margin="-2" StrokeThickness="1.5" Stroke="#5B9CF6"
                                   RadiusX="8" RadiusY="8" SnapsToDevicePixels="True"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern dark scrollbar -->
        <Style x:Key="ScrollBarPageBtn" TargetType="RepeatButton">
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarThumb" TargetType="Thumb">
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThBd" CornerRadius="4" Background="#3A3A3A" Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThBd" Property="Background" Value="#5A5A5A"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThBd" Property="Background" Value="#6E6E6E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="10"/>
                    <Setter Property="MinWidth" Value="10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent">
                                    <Track x:Name="PART_Track" IsDirectionReversed="True">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageBtn}" Command="ScrollBar.PageUpCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumb}" MinHeight="30"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageBtn}" Command="ScrollBar.PageDownCommand"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="10"/>
                    <Setter Property="MinHeight" Value="10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent">
                                    <Track x:Name="PART_Track">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageBtn}" Command="ScrollBar.PageLeftCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumb}" MinWidth="30"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageBtn}" Command="ScrollBar.PageRightCommand"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkCB" TargetType="ComboBox">
            <Setter Property="Foreground"        Value="#E8E8E8"/>
            <Setter Property="Background"        Value="#252525"/>
            <Setter Property="BorderBrush"       Value="#353535"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="FontFamily"        Value="Segoe UI"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkCBItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="Root">
                            <ToggleButton x:Name="TogBtn" Focusable="False" ClickMode="Press"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="TBd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6">
                                            <Path x:Name="Arrow" HorizontalAlignment="Right"
                                                  VerticalAlignment="Center" Margin="0,0,9,0"
                                                  Data="M0,0 L4.5,5 L9,0" Stroke="#777777"
                                                  StrokeThickness="1.5" Fill="Transparent"
                                                  StrokeLineJoin="Round" StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="TBd" Property="Background"  Value="#2E2E2E"/>
                                                <Setter TargetName="TBd" Property="BorderBrush" Value="#555555"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="TBd" Property="BorderBrush" Value="#5B9CF6"/>
                                                <Setter TargetName="Arrow" Property="Stroke"    Value="#5B9CF6"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              Margin="10,0,26,0"
                                              HorizontalAlignment="Left" VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              IsHitTestVisible="False"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                            <Popup x:Name="PART_Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Fade">
                                <Border x:Name="DropBorder"
                                        MinWidth="{Binding ActualWidth, ElementName=Root}"
                                        MaxHeight="280"
                                        Background="#252525" BorderBrush="#454545" BorderThickness="1"
                                        CornerRadius="0,0,6,6">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Opacity="0.6" BlurRadius="10" ShadowDepth="3"/>
                                    </Border.Effect>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" SnapsToDevicePixels="True">
                                        <ItemsPresenter SnapsToDevicePixels="True"
                                                        KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── DataTemplate for ChainedActionViewModel ── -->
        <DataTemplate DataType="{x:Type vm:ChainedActionViewModel}">
            <Grid Margin="0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Actions dropdown -->
                <ComboBox Grid.Column="0" SelectedValue="{Binding Action, Mode=TwoWay}" SelectedValuePath="Kind" DisplayMemberPath="Label" Style="{StaticResource DarkCB}" Height="28" Margin="0,0,6,0">
                    <ComboBox.ItemsSource>
                        <Binding Path="AvailableActions" RelativeSource="{RelativeSource AncestorType={x:Type ItemsControl}, AncestorLevel=2}"/>
                    </ComboBox.ItemsSource>
                </ComboBox>

                <!-- Dynamic Middle Control -->
                <Grid Grid.Column="1" Margin="0,0,6,0">
                    <!-- Shortcut recording mode -->
                    <Grid Visibility="{Binding Action, Converter={StaticResource ActionToVisibilityConverter}, ConverterParameter=Shortcut}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Recording button -->
                        <Button Grid.Column="0" Content="{Binding DisplayRecordText}" Command="{Binding RecordShortcutCommand}" Height="28" Padding="6,0,6,0" HorizontalContentAlignment="Left" FontFamily="Consolas" FontSize="11">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource BtnGhost}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                            <Setter Property="Background" Value="#FFC107"/>
                                            <Setter Property="Foreground" Value="#111111"/>
                                            <Setter Property="BorderBrush" Value="#FFC107"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <!-- Custom text entry box -->
                        <TextBox Grid.Column="0" Text="{Binding OutputValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTB}" Height="28" Visibility="{Binding ShortcutRecordMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                        <!-- Toggle mode button -->
                        <Button Grid.Column="1" Content="{Binding ShortcutRecordMode, Converter={StaticResource RecordModeTextConverter}}" Command="{Binding ToggleRecordModeCommand}" Style="{StaticResource BtnGhost}" Height="28" Width="30" Margin="4,0,0,0" ToolTip="Switch input mode"/>
                    </Grid>

                    <!-- Open App dropdown -->
                    <ComboBox ItemsSource="{Binding Apps}" SelectedItem="{Binding SelectedApp}" Style="{StaticResource DarkCB}" Height="28" Visibility="{Binding Action, Converter={StaticResource ActionToVisibilityConverter}, ConverterParameter=OpenApp}"/>

                    <!-- Open File / Open Folder panels -->
                    <Grid Visibility="{Binding Action, Converter={StaticResource ActionToVisibilityConverter}, ConverterParameter=OpenFileOrFolder}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding DisplayPath}" Foreground="#CCCCCC" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontSize="11" Margin="6,0,6,0"/>
                        <Button Grid.Column="1" Content="Browse..." Command="{Binding BrowseFileCommand}" Style="{StaticResource BtnGhost}" Height="28" Padding="8,0,8,0" Visibility="{Binding Action, Converter={StaticResource ActionToVisibilityConverter}, ConverterParameter=OpenFile}"/>
                        <Button Grid.Column="1" Content="Browse..." Command="{Binding BrowseFolderCommand}" Style="{StaticResource BtnGhost}" Height="28" Padding="8,0,8,0" Visibility="{Binding Action, Converter={StaticResource ActionToVisibilityConverter}, ConverterParameter=OpenFolder}"/>
                    </Grid>

                    <!-- Run Command -->
                    <Grid Visibility="{Binding Action, Converter={StaticResource ActionToVisibilityConverter}, ConverterParameter=Command}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding OutputValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTB}" Height="28" Padding="6,0,6,0"/>
                        <CheckBox Grid.Column="1" Content="show" IsChecked="{Binding CmdShow, Mode=TwoWay}" Style="{StaticResource Toggle}" Margin="6,0,0,0" ToolTip="Show visible console window"/>
                    </Grid>

                    <!-- Type Text -->
                    <TextBox Text="{Binding OutputValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTB}" Height="28" Padding="6,0,6,0" Visibility="{Binding Action, Converter={StaticResource ActionToVisibilityConverter}, ConverterParameter=TypeText}"/>

                    <!-- Switch Profile -->
                    <ComboBox ItemsSource="{Binding Profiles}" DisplayMemberPath="Name" SelectedValuePath="Name" SelectedValue="{Binding SelectedProfileName}" Style="{StaticResource DarkCB}" Height="28" Visibility="{Binding Action, Converter={StaticResource ActionToVisibilityConverter}, ConverterParameter=SwitchProfile}"/>
                </Grid>

                <!-- Custom Step Delay (visible if multi-step) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,6,0" VerticalAlignment="Center" Visibility="{Binding IsMultiStep, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="+ " Foreground="#666666" VerticalAlignment="Center" FontSize="11" FontFamily="Consolas"/>
                    <TextBox Text="{Binding Delay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTB}" Height="24" Width="42" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                    <TextBlock Text=" ms" Foreground="#666666" VerticalAlignment="Center" FontSize="11" FontFamily="Consolas"/>
                </StackPanel>

                <!-- Delete Action button (visible if multi-step) -->
                <Button Grid.Column="3" Content="✕" Command="{Binding DeleteCommand}" Style="{StaticResource BtnGhost}" Width="24" Height="24" ToolTip="Remove this step" Visibility="{Binding IsMultiStep, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>
        </DataTemplate>

        <!-- ── DataTemplate for RowViewModel ── -->
        <DataTemplate DataType="{x:Type vm:RowViewModel}">
            <Grid Margin="0,6,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="175"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Col 0: Indent arrow or Gesture Header -->
                <Grid Grid.Column="0" VerticalAlignment="Top" Margin="0,8,0,0">
                    <TextBlock Text="↳" Foreground="{StaticResource ColorTextMuted}" FontSize="12" Margin="10,0,0,0" Visibility="{Binding IsGlobal, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                    <TextBlock Text="{Binding Label}" Foreground="#CCCCCC" FontSize="12" Visibility="{Binding IsMouseTrigger, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsMouseTrigger}" Value="True"/>
                                            <Condition Binding="{Binding IsGlobal}" Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Col 1: Rounded Card Border -->
                <Border Grid.Column="1" BorderThickness="1" CornerRadius="7" Padding="10,8,10,8" Margin="6,0,4,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#222222"/>
                            <Setter Property="BorderBrush" Value="#333333"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsGlobal}" Value="True">
                                    <Setter Property="Background" Value="#1A1A1A"/>
                                    <Setter Property="BorderBrush" Value="#2A2A2A"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <StackPanel>
                        <!-- Actions stack -->
                        <ItemsControl ItemsSource="{Binding Chain}"/>

                        <Border Height="1" Background="#282828" Margin="0,8,0,8"/>

                        <!-- Footer controls -->
                        <DockPanel LastChildFill="False">
                            <CheckBox IsChecked="{Binding Enabled, Mode=TwoWay}" Style="{StaticResource Toggle}" ToolTip="Toggle enabled state" VerticalAlignment="Center"/>

                            <!-- App Scope button + popup (Only if HasAppScope is true) -->
                            <Grid Visibility="{Binding HasAppScope, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ToggleButton x:Name="ScopeToggleBtn" Content="{Binding AppScopeLabel}" Style="{StaticResource BtnGhost}" Height="26" Margin="6,0,0,0" FontFamily="Consolas" FontSize="11" Padding="6,0,6,0"/>
                                <Popup IsOpen="{Binding IsChecked, ElementName=ScopeToggleBtn, Mode=TwoWay}" StaysOpen="False" Placement="Bottom" PlacementTarget="{Binding ElementName=ScopeToggleBtn}" AllowsTransparency="True" MinWidth="160" MaxWidth="260">
                                    <Border Background="#222222" BorderBrush="#444444" BorderThickness="1" CornerRadius="5" Padding="4" MaxHeight="260">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel>
                                                <!-- Global toggle -->
                                                <CheckBox Content="Global" IsChecked="{Binding IsGlobal, Mode=TwoWay}" Foreground="#E8E8E8" Margin="4" FontFamily="Consolas" FontSize="11"/>
                                                <Rectangle Height="1" Fill="#444444" Margin="0,2,0,2"/>
                                                <!-- Mode Label -->
                                                <TextBlock FontFamily="Consolas" FontSize="10" Margin="4,2,4,2">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Only in:"/>
                                                            <Setter Property="Foreground" Value="#FFC107"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsGlobal}" Value="True">
                                                                    <Setter Property="Text" Value="Except in:"/>
                                                                    <Setter Property="Foreground" Value="#5B9CF6"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <!-- App options -->
                                                <ItemsControl ItemsSource="{Binding AppScopeOptions}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsChecked, Mode=TwoWay}" ToolTip="{Binding ProcessName}" Foreground="#CCCCCC" Margin="4,2,4,2" FontFamily="Consolas" FontSize="11"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>

                            <!-- Debounce Toggle (scroll gestures only) -->
                            <CheckBox Content="debounce" IsChecked="{Binding Debounce, Mode=TwoWay}" Style="{StaticResource Toggle}" ToolTip="Ignore repeat scroll wheel signals within 200ms" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="11" Visibility="{Binding DebounceVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                            <!-- Toast Toggle -->
                            <CheckBox Content="toast" IsChecked="{Binding ShowToast, Mode=TwoWay}" Style="{StaticResource Toggle}" ToolTip="Show on-screen message when fired" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="11"/>

                            <!-- Note label -->
                            <TextBox Text="{Binding NoteLabel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTB}" Width="100" Height="22" VerticalAlignment="Center" Margin="10,0,0,0" ToolTip="Add a custom note"/>

                            <!-- Add step button (footer) -->
                            <Button Content="+ Action" Command="{Binding AddActionCommand}" Style="{StaticResource BtnGhost}" Height="24" Padding="8,0,8,0" Margin="10,0,0,0" VerticalAlignment="Center"/>

                            <!-- Delay text (footer) -->
                            <StackPanel Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <!-- Visible if chain has more than one step -->
                                            <DataTrigger Binding="{Binding Chain.Count}" Value="1">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Chain.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <!-- Greater than 1 → Visible -->
                                            <DataTrigger Binding="{Binding Chain.Count}" Value="2"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                            <DataTrigger Binding="{Binding Chain.Count}" Value="3"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                            <DataTrigger Binding="{Binding Chain.Count}" Value="4"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                            <DataTrigger Binding="{Binding Chain.Count}" Value="5"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="delay " Foreground="#666666" FontSize="10" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding OutputDelay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTB}" Height="22" Width="40" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                                <TextBlock Text=" ms" Foreground="#666666" FontSize="10" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Delete variant row button -->
                            <Button DockPanel.Dock="Right" Content="✕" Command="{Binding DeleteRowCommand}" Style="{StaticResource BtnGhost}" Width="24" Height="24" ToolTip="Delete this variant" VerticalAlignment="Center" Visibility="{Binding IsGlobal, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!-- Col 2: "+" add variant button (Only if global) -->
                <Button Grid.Column="2" Content="+" Command="{Binding AddVariantCommand}" Height="26" Width="26" Margin="2,6,0,0" FontSize="15" ToolTip="Add app-specific variant" VerticalAlignment="Top">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource BtnGhost}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsMouseTrigger}" Value="True"/>
                                        <Condition Binding="{Binding IsGlobal}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </DataTemplate>

        <!-- ── DataTemplate for MouseTriggerGroupViewModel ── -->
        <DataTemplate DataType="{x:Type vm:MouseTriggerGroupViewModel}">
            <StackPanel Margin="0,0,0,16">
                <!-- Header -->
                <DockPanel LastChildFill="False" Margin="0,0,0,6">
                    <TextBlock local:HighlightableTextBehavior.FullText="{Binding Label}" local:HighlightableTextBehavior.HighlightPattern="{Binding DataContext.SearchText, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="#BBBBBB" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Content="+ Add app variant" Command="{Binding AddVariantCommand}" Style="{StaticResource BtnGhost}" Height="24" Padding="10,0,10,0"/>
                </DockPanel>
                <!-- Variants rows -->
                <ItemsControl ItemsSource="{Binding Variants}"/>
            </StackPanel>
        </DataTemplate>

        <!-- ── DataTemplate for KbdTriggerCardViewModel ── -->
        <DataTemplate DataType="{x:Type vm:KbdTriggerCardViewModel}">
            <Border Style="{StaticResource Card}" BorderBrush="#2A2A2A" BorderThickness="1" Margin="0,0,0,6" Padding="12,10,12,10">
                <StackPanel>
                    <!-- Header -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Key Capture button -->
                        <Button Grid.Column="0" Content="{Binding DisplayTrigger}" Command="{Binding RecordCommand}" Height="28" Padding="10,0,10,0" FontFamily="Consolas" FontSize="11" ToolTip="Click to record hotkey">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource BtnGhost}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                            <Setter Property="Background" Value="#FFC107"/>
                                            <Setter Property="Foreground" Value="#111111"/>
                                            <Setter Property="BorderBrush" Value="#FFC107"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Variants add variant "+ App" button -->
                        <Button Grid.Column="1" Content="+ App" Command="{Binding AddVariantCommand}" Style="{StaticResource BtnGhost}" Height="28" Padding="10,0,10,0" Margin="8,0,0,0" HorizontalAlignment="Left" ToolTip="Add app-scoped override"/>

                        <!-- Delete trigger card -->
                        <Button Grid.Column="2" Content="✕" Command="{Binding DeleteCardCommand}" Style="{StaticResource BtnGhost}" Width="28" Height="28" Padding="0" FontSize="11" ToolTip="Delete this trigger card"/>
                    </Grid>

                    <!-- Variants list -->
                    <ItemsControl ItemsSource="{Binding Variants}"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ── DataTemplate for AppTriggerCardViewModel ── -->
        <DataTemplate DataType="{x:Type vm:AppTriggerCardViewModel}">
            <Border Style="{StaticResource Card}" BorderBrush="#2A2A2A" BorderThickness="1" Margin="0,0,0,6" Padding="12,10,12,10">
                <StackPanel>
                    <!-- Header -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Kind ComboBox -->
                        <ComboBox Grid.Column="0" SelectedIndex="{Binding SelectedKindIndex, Mode=TwoWay}" Style="{StaticResource DarkCB}" Height="28" Width="110" FontFamily="Consolas" FontSize="11">
                            <ComboBoxItem Content="App launches"/>
                            <ComboBoxItem Content="App exits"/>
                            <ComboBoxItem Content="App focus"/>
                            <ComboBoxItem Content="App blur"/>
                        </ComboBox>

                        <!-- App Picker Toggle Button & Popup -->
                        <Grid Grid.Column="1" Margin="8,0,0,0">
                            <ToggleButton x:Name="AppPickerToggle" Content="{Binding AppsLabel}" Style="{StaticResource BtnGhost}" Height="28" FontFamily="Consolas" FontSize="11" Padding="8,0,8,0" HorizontalContentAlignment="Left"/>
                            <Popup IsOpen="{Binding IsChecked, ElementName=AppPickerToggle, Mode=TwoWay}" StaysOpen="False" Placement="Bottom" PlacementTarget="{Binding ElementName=AppPickerToggle}" AllowsTransparency="True" MinWidth="180" MaxWidth="300">
                                <Border Background="#222222" BorderBrush="#444444" BorderThickness="1" CornerRadius="5" Padding="4" MaxHeight="260">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel>
                                            <!-- Standard Apps checkboxes -->
                                            <ItemsControl ItemsSource="{Binding AppOptions}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsChecked, Mode=TwoWay}" ToolTip="{Binding ProcessName}" Foreground="#CCCCCC" Margin="4,2,4,2" FontFamily="Consolas" FontSize="11"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <!-- Custom app text input -->
                                            <Rectangle Height="1" Fill="#444444" Margin="0,4,0,4"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="CustomAppTxt" Text="{Binding CustomAppInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTB}" Height="24" FontSize="11"/>
                                                <TextBlock Text="Add process..." Foreground="#444444" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0" IsHitTestVisible="False" Visibility="{Binding Text, ElementName=CustomAppTxt, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                                <Button Grid.Column="1" Content="+" Command="{Binding AddCustomAppCommand}" Style="{StaticResource BtnGhost}" Width="24" Height="24" Margin="4,0,0,0"/>
                                            </Grid>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <!-- Delete trigger card -->
                        <Button Grid.Column="2" Content="✕" Command="{Binding DeleteCardCommand}" Style="{StaticResource BtnGhost}" Width="28" Height="28" Padding="0" FontSize="11" ToolTip="Remove this trigger"/>
                    </Grid>

                    <!-- The Single Row variant -->
                    <ContentControl Content="{Binding Row}"/>
                </StackPanel>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════ TOP BAR ═══════════ -->
        <Border Grid.Row="0" Background="#0E0E0E" BorderBrush="#1E1E1E" BorderThickness="0,0,0,1">
            <Grid Height="48" Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App title -->
                <TextBlock Grid.Column="0" Text="Shortcut Hook" Foreground="#EFEFEF" FontSize="15"
                           FontWeight="SemiBold" VerticalAlignment="Center"/>

                <!-- Paused badge -->
                <Border Grid.Column="1" Background="#3A3210" CornerRadius="4"
                        Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center"
                        Margin="16,0,0,0" Visibility="{Binding IsPaused, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="⏸ Paused" Foreground="#E8C25C" FontSize="11" FontWeight="SemiBold"/>
                </Border>

                <!-- Status dot + text + hook button -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="{Binding StatusDotBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding HookStatusText}" Foreground="{StaticResource ColorTextDim}" FontSize="12"
                               VerticalAlignment="Center" Margin="7,0,12,0"/>
                    <Button Command="{Binding HookBtnCommand}" Background="{StaticResource ColorPrimary}"
                            Height="28" Width="66" Padding="0" FontSize="12">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
                                <Setter Property="Content" Value="Start"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHookRunning}" Value="True">
                                        <Setter Property="Content" Value="Stop"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════ MAIN CONTENT (sidebar + content) ═══════════ -->
        <Grid x:Name="MainAppRoot" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─── SIDEBAR ─── -->
            <Border Grid.Column="0" Background="#0C0C0C">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="PROFILES" Style="{StaticResource SectionLabel}"
                               Margin="14,14,14,8"/>

                    <!-- Profiles list -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Profiles}" Margin="6,0,6,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,7,6,7" CornerRadius="6" Margin="0,1,0,1" Cursor="Hand">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="#1A2A3A"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource ColorPrimary}"/>
                                                        <Setter Property="BorderThickness" Value="2,0,0,0"/>
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsSelected}" Value="False"/>
                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="#242424"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick" Command="{Binding SelectCommand}"/>
                                        </Border.InputBindings>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#AAAAAA"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Foreground" Value="#5B9CF6"/>
                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- Pencil/delete actions on hover -->
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </MultiDataTrigger>
                                                            <DataTrigger Binding="{Binding Name}" Value="Default">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <Button Content="✏" Command="{Binding RenameCommand}" Style="{StaticResource BtnGhost}" Width="22" Height="22" Padding="0" FontSize="11" Margin="0,0,2,0" ToolTip="Rename"/>
                                                <Button Content="✕" Command="{Binding DeleteCommand}" Style="{StaticResource BtnGhost}" Width="22" Height="22" Padding="0" FontSize="10" ToolTip="Delete"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Button Grid.Row="2" Command="{Binding SidebarAddProfileCommand}"
                            Style="{StaticResource BtnGhost}" Height="30"
                            Margin="8,6,8,4" Padding="0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="+" Foreground="#666666" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="New Profile" Foreground="#888888" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <StackPanel Grid.Row="3">
                        <Border Height="1" Background="#1A1A1A" Margin="8,0"/>
                        <Button Command="{Binding SidebarSettingsCommand}"
                                Style="{StaticResource BtnGhost}" Height="30"
                                Margin="8,4,8,8" Padding="8,0"
                                HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#9881;" FontSize="12" Foreground="#555555"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Settings" FontFamily="Segoe UI" FontSize="11"
                                           Foreground="#666666" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ─── DIVIDER ─── -->
            <Border Grid.Column="1" Background="#1E1E1E"/>

            <!-- ─── MAIN CONTENT ─── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Update banner -->
                <Border Grid.Row="0" Style="{StaticResource Card}"
                        Background="#2A2410" BorderBrush="#4A3F1A" Margin="12,10,12,0" Visibility="{Binding ShowUpdateBanner, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding UpdateBannerText}" VerticalAlignment="Center"
                                   Foreground="#E8C25C" FontSize="13" TextWrapping="Wrap"/>
                        <TextBlock Grid.Column="1" Text="Download" Cursor="Hand" VerticalAlignment="Center"
                                   Foreground="#E8C25C" FontSize="13" FontWeight="SemiBold"
                                   TextDecorations="Underline" Margin="12,0,12,0"
                                   MouseLeftButtonDown="UpdateDownloadCommand"/>
                        <Button Grid.Column="2" Content="&#10005;" Command="{Binding UpdateDismissCommand}" Style="{StaticResource BtnGhost}"
                                Width="28" Height="24" Padding="0" FontSize="11" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Search + import bar -->
                <Border Grid.Row="1" Margin="12,10,12,2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid>
                            <TextBox x:Name="SearchBox" Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTB}" Height="32"
                                     Padding="10,0" FontFamily="Segoe UI" FontSize="12"/>
                            <TextBlock Text="Search bindings..."
                                       Foreground="#3A3A3A" FontSize="12" FontFamily="Segoe UI"
                                       VerticalAlignment="Center" Margin="18,0,0,0"
                                       IsHitTestVisible="False" Visibility="{Binding Text, ElementName=SearchBox, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                        </Grid>
                        <Button Grid.Column="1" Command="{Binding ClearSearchCommand}"
                                Width="30" Height="30"
                                Padding="0" Margin="6,0,0,0" ToolTip="Clear search">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource BtnGhost}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>
                        <Button Grid.Column="2" Command="{Binding ImportBindingCommand}"
                                Style="{StaticResource BtnGhost}" Height="30" Padding="10,0"
                                Margin="6,0,0,0"
                                ToolTip="Import a binding from clipboard JSON">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE77F;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Import" FontFamily="Segoe UI" FontSize="11"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- Tab bar -->
                <Border Grid.Row="2" BorderBrush="#1E1E1E" BorderThickness="0,0,0,1" Margin="0,4,0,0">
                    <StackPanel Orientation="Horizontal" Margin="4,0,0,0">
                        <Button Command="{Binding TabAllCommand}" Style="{StaticResource BtnTab}">
                            <Button.Tag>
                                <Binding Path="TabAllActive" Converter="{StaticResource RecordModeTextConverter}" ConverterParameter="active"/>
                            </Button.Tag>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="All"/>
                                <TextBlock Text="{Binding TabAllBadge}" Margin="5,0,0,0" FontSize="11"
                                           Foreground="#555555" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding TabMouseCommand}" Style="{StaticResource BtnTab}">
                            <Button.Tag>
                                <Binding Path="TabMouseActive" Converter="{StaticResource RecordModeTextConverter}" ConverterParameter="active"/>
                            </Button.Tag>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Mouse"/>
                                <TextBlock Text="{Binding TabMouseBadge}" Margin="5,0,0,0" FontSize="11"
                                           Foreground="#555555" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding TabKbdCommand}" Style="{StaticResource BtnTab}">
                            <Button.Tag>
                                <Binding Path="TabKbdActive" Converter="{StaticResource RecordModeTextConverter}" ConverterParameter="active"/>
                            </Button.Tag>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Keyboard"/>
                                <TextBlock Text="{Binding TabKbdBadge}" Margin="5,0,0,0" FontSize="11"
                                           Foreground="#555555" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding TabAppSpecificCommand}" Style="{StaticResource BtnTab}">
                            <Button.Tag>
                                <Binding Path="TabAppSpecificActive" Converter="{StaticResource RecordModeTextConverter}" ConverterParameter="active"/>
                            </Button.Tag>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="App-specific"/>
                                <TextBlock Text="{Binding TabAppSpecificBadge}" Margin="5,0,0,0" FontSize="11"
                                           Foreground="#555555" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Binding sections scroll -->
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="12,4,8,0">
                    <StackPanel Margin="0,0,4,8">

                        <!-- Mouse card -->
                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource Card}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilteredMouseTriggers.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <Grid Cursor="Hand" Background="Transparent">
                                    <Grid.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding ToggleMouseAccordionCommand}"/>
                                    </Grid.InputBindings>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="MOUSE SHORTCUTS" Style="{StaticResource SectionLabel}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding MouseChevronText}"
                                               Foreground="#555555" FontSize="11" VerticalAlignment="Center"/>
                                </Grid>
                                <StackPanel Margin="0,10,0,0" Visibility="{Binding MouseExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <ItemsControl x:Name="MouseItemsControl" ItemsSource="{Binding FilteredMouseTriggers}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Keyboard card -->
                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource Card}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <!-- Hide if tab is Mouse/AppSpecific OR no matching items -->
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding FilteredKbdTriggers.Count}" Value="0"/>
                                                <Condition Binding="{Binding ActiveTab}" Value="All"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </MultiDataTrigger>
                                        <DataTrigger Binding="{Binding ActiveTab}" Value="Mouse">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ActiveTab}" Value="AppSpecific">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <Grid Cursor="Hand" Background="Transparent">
                                    <Grid.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding ToggleKbdAccordionCommand}"/>
                                    </Grid.InputBindings>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="KEYBOARD SHORTCUTS" Style="{StaticResource SectionLabel}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding KbdChevronText}"
                                               Foreground="#555555" FontSize="11" VerticalAlignment="Center"/>
                                </Grid>
                                <StackPanel Margin="0,8,0,0" Visibility="{Binding KbdExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <DockPanel Margin="0,0,0,8">
                                        <Button Command="{Binding AddKbdTriggerCommand}" DockPanel.Dock="Right" Content="+ New trigger"
                                                Style="{StaticResource BtnGhost}" Height="24" Width="90" Padding="0"
                                                HorizontalAlignment="Right"/>
                                    </DockPanel>
                                    <ItemsControl x:Name="KbdItemsControl" ItemsSource="{Binding FilteredKbdTriggers}"/>
                                    <TextBlock Margin="0,8,0,0"
                                               Text="Each card is one trigger. Use '+ App' to add app-specific overrides. Esc cancels capture."
                                               Foreground="#3A3A3A" FontSize="11" TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- App Triggers card -->
                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource Card}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding FilteredAppTriggers.Count}" Value="0"/>
                                                <Condition Binding="{Binding ActiveTab}" Value="All"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </MultiDataTrigger>
                                        <DataTrigger Binding="{Binding ActiveTab}" Value="Mouse">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ActiveTab}" Value="Kbd">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <Grid Cursor="Hand" Background="Transparent">
                                    <Grid.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding ToggleAppTriggersAccordionCommand}"/>
                                    </Grid.InputBindings>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="APP TRIGGERS" Style="{StaticResource SectionLabel}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding AppTriggersChevronText}"
                                               Foreground="#555555" FontSize="11" VerticalAlignment="Center"/>
                                </Grid>
                                <StackPanel Margin="0,8,0,0" Visibility="{Binding AppTriggersExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <DockPanel Margin="0,0,0,8">
                                        <Button Command="{Binding AddAppTriggerCommand}" DockPanel.Dock="Right" Content="+ New trigger"
                                                Style="{StaticResource BtnGhost}" Height="24" Width="90" Padding="0"
                                                HorizontalAlignment="Right"/>
                                    </DockPanel>
                                    <ItemsControl x:Name="AppItemsControl" ItemsSource="{Binding FilteredAppTriggers}"/>
                                    <TextBlock Margin="0,8,0,0"
                                               Text="Fires when a named process starts, exits, gains focus, or loses focus. Select one or more processes per trigger."
                                               Foreground="#3A3A3A" FontSize="11" TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- ─── SAVE BAR ─── -->
                <Border Grid.Row="4" Background="#141414" BorderBrush="#232323" BorderThickness="0,1,0,0" Padding="14,10">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <TranslateTransform Y="0"/>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowSaveBar}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="40" To="0" Duration="0:0:0.18">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding FeedbackMessage}" Foreground="{Binding FeedbackBrush}" VerticalAlignment="Center" FontSize="12" TextWrapping="Wrap" Visibility="{Binding ShowFeedback, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <Button Grid.Column="1" Content="Save Changes" Command="{Binding SaveBtnCommand}" Background="#5B9CF6" Style="{StaticResource BtnPrimary}" Height="36" Padding="20,0" FontSize="13"/>
                    </Grid>
                </Border>

            </Grid>
        </Grid>

        <!-- ═══════════ SETUP OVERLAY ═══════════ -->
        <Border x:Name="SetupRoot" Grid.Row="0" Grid.RowSpan="2" Background="#111111" Visibility="{Binding ShowSetup, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid Margin="28,24,28,24">
                <Border Style="{StaticResource Card}" MaxWidth="620" HorizontalAlignment="Center" VerticalAlignment="Top" Padding="24,22">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock Text="First-Time Setup" Foreground="#EFEFEF" FontSize="24" FontWeight="Bold"/>
                            <TextBlock Text="Complete these steps once. After setup, ShortcutHook will open straight into the main app."
                                       Foreground="#777777" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"/>

                            <Border Background="#171717" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="10" Margin="0,20,0,0" Padding="16,14">
                                <StackPanel>
                                    <TextBlock Text="1. Install" Foreground="#F1F1F1" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="Choose where to install the app. The daemon script is always placed at a fixed path."
                                               Foreground="#777777" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="52"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="App:" Foreground="#777777" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SetupAppFolderText}"
                                                   Foreground="#5B9CF6" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Script:" Foreground="#777777" FontSize="12" VerticalAlignment="Center" Margin="0,5,0,0"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SetupScriptFolderText}"
                                                   Foreground="#555555" FontSize="12" VerticalAlignment="Center" Margin="0,5,0,0"/>
                                    </Grid>
                                    <TextBlock Text="{Binding SetupInstallStatusText}"
                                               Foreground="#BBBBBB" FontSize="12" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                        <Button Content="Choose App Folder and Install" Background="#5B9CF6" Style="{StaticResource BtnPrimary}" Width="210" Height="36" Padding="0" Click="InstallBtn_Click"/>
                                        <Button Content="Open Script Folder" Style="{StaticResource BtnGhost}" Width="130" Height="36" Padding="0" Margin="10,0,0,0" Click="OpenInstallBtn_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Background="#171717" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="10" Margin="0,12,0,0" Padding="16,14">
                                <StackPanel>
                                    <TextBlock Text="2. Add Start Menu Shortcut" Foreground="#F1F1F1" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="Optional. This adds ShortcutHook to Start Menu so it behaves like a regular installed app."
                                               Foreground="#777777" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                    <CheckBox IsChecked="{Binding SetupStartMenu, Mode=TwoWay}" Content="Create Start Menu shortcut" Style="{StaticResource Toggle}" Margin="0,12,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#171717" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="10" Margin="0,12,0,0" Padding="16,14">
                                <StackPanel>
                                    <TextBlock Text="3. Create Desktop Shortcut" Foreground="#F1F1F1" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="Optional. This places a ShortcutHook shortcut on the desktop."
                                               Foreground="#777777" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                    <CheckBox IsChecked="{Binding SetupDesktop, Mode=TwoWay}" Content="Create desktop shortcut" Style="{StaticResource Toggle}" Margin="0,12,0,0"/>
                                </StackPanel>
                            </Border>

                            <Button Content="Finish Setup" Background="{StaticResource ColorPrimary}" Style="{StaticResource BtnPrimary}" Height="42" Padding="0" FontSize="14" Margin="0,18,0,0" IsEnabled="{Binding CompleteSetupEnabled}" Click="CompleteSetupBtn_Click"/>
                            <TextBlock Text="{Binding SetupHintText}" Foreground="#777777" FontSize="12" Margin="0,10,0,0" TextAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════ COMMAND PALETTE ═══════════ -->
        <Grid x:Name="CommandPaletteRoot" Grid.Row="0" Grid.RowSpan="2" Background="#BB000000"
              Visibility="Collapsed" MouseDown="CommandPaletteRoot_MouseDown">
            <Border Background="#1C1C1C" BorderBrush="#333333" BorderThickness="1" CornerRadius="10"
                    Width="560" MaxHeight="480" HorizontalAlignment="Center" VerticalAlignment="Top"
                    Margin="0,72,0,0" MouseDown="CommandPaletteCard_MouseDown" ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.75" BlurRadius="28" ShadowDepth="4"/>
                </Border.Effect>
                <DockPanel>
                    <!-- Search input -->
                    <Border DockPanel.Dock="Top" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1" Padding="14,11,14,11">
                        <Grid>
                            <TextBlock Text="⌘" Foreground="#3A3A3A" FontSize="15"
                                       VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <TextBox x:Name="PaletteSearchBox" Style="{StaticResource DarkTB}"
                                     Background="Transparent" BorderThickness="0" Padding="28,0,0,0"
                                     FontSize="14" Height="30" TextChanged="PaletteSearch_TextChanged" KeyDown="PaletteSearchBox_KeyDown"/>
                            <TextBlock x:Name="PaletteSearchPlaceholder"
                                       Text="Search bindings or type an action..."
                                       Foreground="#333333" FontSize="14" FontFamily="Segoe UI"
                                       VerticalAlignment="Center" Margin="30,0,0,0" IsHitTestVisible="False"/>
                        </Grid>
                    </Border>
                    <!-- Results -->
                    <ScrollViewer x:Name="PaletteResultsScroll" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="PaletteResultsStack" Margin="6,4,6,6"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ═══════════ UPDATE OVERLAY ═══════════ -->
        <Border x:Name="UpdateOverlay" Grid.Row="0" Grid.RowSpan="2" Background="#CC000000" Visibility="{Binding ShowUpdateOverlay, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid Margin="28,24,28,24">
                <Border Style="{StaticResource Card}" MaxWidth="520" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="24,22">
                    <StackPanel>
                        <TextBlock Text="App Update Available" Foreground="#EFEFEF" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="{Binding UpdateOverlayMessageText}" Foreground="#CCCCCC" FontSize="13" Margin="0,12,0,0" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding UpdateOverlayPathText}" Foreground="#777777" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>

                        <StackPanel Orientation="Horizontal" Margin="0,24,0,0" HorizontalAlignment="Right">
                            <Button Content="Run Without Updating" Command="{Binding UpdateOverlayCancelCommand}" Style="{StaticResource BtnGhost}" Height="36" Padding="16,0"/>
                            <Button Content="Install Update" Command="{Binding UpdateOverlayInstallCommand}" Background="#5B9CF6" Style="{StaticResource BtnPrimary}" Height="36" Padding="20,0" Margin="12,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════ SETTINGS OVERLAY ═══════════ -->
        <Border x:Name="SettingsRoot" Grid.Row="0" Grid.RowSpan="2" Background="#CC000000" Visibility="{Binding ShowSettings, Converter={StaticResource BooleanToVisibilityConverter}}" MouseDown="SettingsRoot_MouseDown">
            <Border Background="#171717" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="10"
                    Width="600" Height="460" HorizontalAlignment="Center" VerticalAlignment="Center"
                    MouseDown="SettingsCard_MouseDown" ClipToBounds="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="175"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- NAV SIDEBAR -->
                    <Border Grid.Column="0" Background="#111111" CornerRadius="9,0,0,9">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Settings" Foreground="#EFEFEF"
                                       FontSize="15" FontWeight="Bold" Margin="16,18,16,14"/>
                            <StackPanel Margin="8,0">
                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource SettingsNavItem}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DaemonViewActive}" Value="True">
                                                    <Setter Property="Background" Value="#1E1E1E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding NavDaemonCommand}"/>
                                    </Border.InputBindings>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚙" FontSize="14" Foreground="#888888" Width="22" VerticalAlignment="Center"/>
                                        <TextBlock Text="Daemon" Foreground="#CCCCCC" FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource SettingsNavItem}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ProfilesViewActive}" Value="True">
                                                    <Setter Property="Background" Value="#1E1E1E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding NavProfilesCommand}"/>
                                    </Border.InputBindings>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="◈" FontSize="14" Foreground="#888888" Width="22" VerticalAlignment="Center"/>
                                        <TextBlock Text="Profiles" Foreground="#CCCCCC" FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource SettingsNavItem}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IgnoredAppsViewActive}" Value="True">
                                                    <Setter Property="Background" Value="#1E1E1E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding NavIgnoredAppsCommand}"/>
                                    </Border.InputBindings>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⊘" FontSize="14" Foreground="#888888" Width="22" VerticalAlignment="Center"/>
                                        <TextBlock Text="Ignored Apps" Foreground="#CCCCCC" FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource SettingsNavItem}">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding NavLogsCommand}"/>
                                    </Border.InputBindings>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="≡" FontSize="17" Foreground="#888888" Width="22" VerticalAlignment="Center"/>
                                        <TextBlock Text="Logs" Foreground="#CCCCCC" FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource SettingsNavItem}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AboutViewActive}" Value="True">
                                                    <Setter Property="Background" Value="#1E1E1E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding NavAboutCommand}"/>
                                    </Border.InputBindings>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="ⓘ" FontSize="14" Foreground="#888888" Width="22" VerticalAlignment="Center"/>
                                        <TextBlock Text="About" Foreground="#CCCCCC" FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- DIVIDER -->
                    <Border Grid.Column="1" Background="#2A2A2A"/>

                    <!-- RIGHT CONTENT -->
                    <Grid Grid.Column="2" Margin="20,18,20,18">

                        <!-- Daemon settings -->
                        <StackPanel Visibility="{Binding DaemonViewActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Daemon" Foreground="#EFEFEF" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,14"/>
                            <Border Style="{StaticResource SettingsOptionCard}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Launch on Windows Login" Foreground="#EFEFEF" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="Start the daemon automatically on login" Foreground="#777777" FontSize="11" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <CheckBox IsChecked="{Binding StartupLaunchOnLogin, Mode=TwoWay}" Command="{Binding StartupToggleCommand}" Grid.Column="1" Style="{StaticResource Toggle}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Background="#1A1A1A" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,8,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="HOOK STATUS" Foreground="#555555" FontSize="10" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding DaemonStatusDetail}" Foreground="#AAAAAA" FontSize="12" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <Ellipse Grid.Column="1" Width="8" Height="8" VerticalAlignment="Center" Fill="{Binding DaemonStatusDotBrush}"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Profiles Settings -->
                        <StackPanel Visibility="{Binding ProfilesViewActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding ProfilesViewActive}" Value="True"/>
                                                <Condition Binding="{Binding ShowProfileForm}" Value="False"/>
                                                <Condition Binding="{Binding ShowProfileDelete}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <DockPanel Margin="0,0,0,4">
                                <TextBlock Text="Profiles" Foreground="#EFEFEF" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Button Command="{Binding AddProfileBtnCommand}" DockPanel.Dock="Right" Content="+ Add" Style="{StaticResource BtnGhost}" HorizontalAlignment="Right" Height="28" Padding="12,0"/>
                            </DockPanel>
                            <TextBlock Text="Click a profile to select it for export." Foreground="#777777" FontSize="11" Margin="0,2,0,8"/>
                            <ScrollViewer MaxHeight="230" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding Profiles}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,8,10,8" CornerRadius="6" Background="Transparent" BorderThickness="1" Margin="0,0,0,4" Cursor="Hand">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelectedForExport}" Value="True">
                                                                <Setter Property="BorderBrush" Value="{StaticResource ColorPrimary}"/>
                                                            </DataTrigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#242424"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick" Command="{Binding SelectForExportCommand}"/>
                                                </Border.InputBindings>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <RadioButton IsChecked="{Binding IsSelected, Mode=OneWay}" Style="{StaticResource DarkRadio}" GroupName="ActiveProfileSettingsGroup" VerticalAlignment="Center" Margin="0,0,10,0" Command="{Binding SelectCommand}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{StaticResource ColorTextPrimary}" FontSize="13" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Visibility="Collapsed">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Style.Triggers>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </MultiDataTrigger>
                                                                    <DataTrigger Binding="{Binding Name}" Value="Default">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <Button Content="Edit" Command="{Binding RenameCommand}" Style="{StaticResource BtnGhost}" Width="52" Height="26" Padding="0" FontSize="11"/>
                                                        <Button Content="Delete" Command="{Binding DeleteCommand}" Style="{StaticResource BtnGhost}" Width="58" Height="26" Padding="0" FontSize="11" Margin="6,0,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Command="{Binding ExportProfileBtnCommand}" Content="Export" Style="{StaticResource BtnGhost}" Height="28" Padding="12,0" IsEnabled="{Binding SelectedProfileForExport, Converter={StaticResource ActionToVisibilityConverter}, ConverterParameter=OpenFileOrFolder}"/>
                                <Button Command="{Binding ImportProfileBtnCommand}" Content="Import" Style="{StaticResource BtnGhost}" Height="28" Padding="12,0" Margin="8,0,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Ignored Apps -->
                        <StackPanel Visibility="{Binding IgnoredAppsViewActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Ignored Apps" Foreground="#EFEFEF" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="All shortcuts are suppressed while one of these apps is focused." Foreground="#777777" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>
                            <ScrollViewer MaxHeight="210" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding IgnoredApps}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#202020" BorderBrush="#333333" BorderThickness="1" CornerRadius="6" Padding="10,6" Margin="0,0,0,4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding}" Foreground="#EFEFEF" VerticalAlignment="Center" FontFamily="Consolas"/>
                                                    <Button Grid.Column="1" Content="✕" Style="{StaticResource BtnGhost}" Width="20" Height="20" Padding="0" FontSize="10" VerticalAlignment="Center"
                                                            Command="{Binding DataContext.IgnoredApps.Remove, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding IgnoredAppsCustomInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTB}" Height="30" Padding="8,0" FontFamily="Consolas" FontSize="11"/>
                                <Button Command="{Binding IgnoredAppsAddCustomCommand}" Grid.Column="1" Content="Add" Style="{StaticResource BtnGhost}" Height="30" Padding="12,0" Margin="6,0,0,0"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Button Command="{Binding IgnoredAppsSaveCommand}" Content="Save" Background="#5B9CF6" Style="{StaticResource BtnPrimary}" Height="34" Width="90" Padding="0"/>
                                <Button Command="{Binding IgnoredAppsCancelCommand}" Content="Cancel" Style="{StaticResource BtnGhost}" Height="34" Width="90" Padding="0" Margin="8,0,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Profile Add/Rename Sub-View -->
                        <StackPanel Visibility="{Binding ShowProfileForm, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding ProfileFormTitle}" Foreground="#EFEFEF" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,14"/>
                            <TextBox Text="{Binding ProfileNameBox, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTB}" Height="34" Padding="10,0" MaxLength="32"/>
                            <TextBlock Text="{Binding ProfileFormError}" Foreground="{StaticResource ColorDanger}" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ProfileFormError}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ProfileFormError, Converter={StaticResource ActionToVisibilityConverter}, ConverterParameter=OpenFileOrFolder}" Value="True">
                                                <!-- Custom fallback to show if error length > 0 -->
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                <Button Command="{Binding ProfileFormConfirmCommand}" Content="Confirm" Background="#5B9CF6" Style="{StaticResource BtnPrimary}" Height="34" Width="90" Padding="0"/>
                                <Button Command="{Binding ProfileFormCancelCommand}" Content="Cancel" Style="{StaticResource BtnGhost}" Height="34" Width="90" Padding="0" Margin="8,0,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Profile Delete Sub-View -->
                        <StackPanel Visibility="{Binding ShowProfileDelete, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Delete Profile" Foreground="#EFEFEF" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <TextBlock Text="{Binding ProfileDeleteMsg}" Foreground="#CCCCCC" FontSize="13" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding ProfileDeleteError}" Foreground="{StaticResource ColorDanger}" FontSize="11" Margin="0,10,0,0" TextWrapping="Wrap" Visibility="{Binding ProfileDeleteError, Converter={StaticResource ActionToVisibilityConverter}, ConverterParameter=OpenFileOrFolder}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                <Button Command="{Binding ProfileDeleteConfirmCommand}" Content="Delete" Background="{StaticResource ColorDanger}" Style="{StaticResource BtnPrimary}" Height="34" Width="90" Padding="0"/>
                                <Button Command="{Binding ProfileDeleteCancelCommand}" Content="Cancel" Style="{StaticResource BtnGhost}" Height="34" Width="90" Padding="0" Margin="8,0,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- About settings -->
                        <StackPanel Visibility="{Binding AboutViewActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Image Source="pack://application:,,,/Assets/ShortcutHook.png" Width="48" Height="48" HorizontalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="ShortcutHook" Foreground="#EFEFEF" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding SettingsVersionText}" Foreground="#555555" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,14,0,0">
                                <TextBlock Text="by " Foreground="#666666" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock Text="Veera Bharath" Foreground="#AAAAAA" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Style="{StaticResource BtnGhost}" Height="36" Padding="14,0" HorizontalAlignment="Center" Margin="0,14,0,0" Click="SettingsGitHubBtn_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Viewbox Width="16" Height="16">
                                        <Path Fill="#CCCCCC" Data="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703 -2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466 -.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032 .892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338 -2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688 -.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026 A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337 c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651 .64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942 .359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
                                    </Viewbox>
                                    <TextBlock Text="GitHub" Foreground="#CCCCCC" FontSize="13" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                    </Grid>
                </Grid>
            </Border>
        </Border>

    </Grid>
</Window>
