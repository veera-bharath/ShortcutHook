<Window x:Class="ShortcutHookUI.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About ShortcutHook" Width="340" Height="340"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#111111" FontFamily="Segoe UI"
        Icon="pack://application:,,,/Assets/ShortcutHook.ico">

    <Window.Resources>
        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#CCCCCC"/>
            <Setter Property="BorderBrush"     Value="#2E2E2E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"  Value="#1F1F1F"/>
                                <Setter Property="BorderBrush" Value="#555555"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Margin="32,24,32,24">

        <!-- Close pinned to bottom -->
        <Button DockPanel.Dock="Bottom" Content="Close" Style="{StaticResource GhostBtn}"
                Height="34" Width="90" HorizontalAlignment="Center" Margin="0,16,0,0"
                Click="CloseBtn_Click"/>

        <!-- Main content centred in remaining space -->
        <StackPanel VerticalAlignment="Center">

            <Image Source="pack://application:,,,/Assets/ShortcutHook.png"
                   Width="52" Height="52" HorizontalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <TextBlock Text="ShortcutHook" Foreground="#EFEFEF" FontSize="22"
                       FontWeight="Bold" HorizontalAlignment="Center" Margin="0,12,0,0"/>

            <TextBlock x:Name="VersionText" Foreground="#555555" FontSize="12"
                       HorizontalAlignment="Center" Margin="0,4,0,0"/>

            <Border Background="#222222" Height="1" Margin="0,20,0,0"/>

            <TextBlock Foreground="#666666" FontSize="12"
                       HorizontalAlignment="Center" Margin="0,18,0,0">
                <Run>by </Run><Run Foreground="#AAAAAA" FontWeight="SemiBold">veerabharath123</Run>
            </TextBlock>

            <!-- GitHub button -->
            <Button Style="{StaticResource GhostBtn}" Height="36" Padding="14,0"
                    HorizontalAlignment="Center" Margin="0,10,0,0"
                    Click="GitHubBtn_Click">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- GitHub mark -->
                    <Viewbox Width="16" Height="16">
                        <Path Fill="#CCCCCC" Data="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18
                              6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703
                              -2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466
                              -.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032
                              .892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338
                              -2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688
                              -.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026
                              A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337
                              c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651
                              .64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942
                              .359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747
                              0 .268.18.58.688.482A10.019 10.019 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
                    </Viewbox>
                    <TextBlock Text="GitHub" Foreground="#CCCCCC" FontSize="13"
                               Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

        </StackPanel>
    </DockPanel>
</Window>
