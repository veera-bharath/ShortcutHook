<Window x:Class="ShortcutHookUI.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About ShortcutHook" Width="340" Height="300"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#111111" FontFamily="Segoe UI"
        Icon="pack://application:,,,/Assets/ShortcutHook.ico">

    <Window.Resources>
        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="#CCCCCC"/>
            <Setter Property="BorderBrush"      Value="#2E2E2E"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"  Value="#1F1F1F"/>
                                <Setter Property="BorderBrush" Value="#555555"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="32,26,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Image Grid.Row="0" Source="pack://application:,,,/Assets/ShortcutHook.png"
               Width="52" Height="52" HorizontalAlignment="Center"
               RenderOptions.BitmapScalingMode="HighQuality"/>

        <TextBlock Grid.Row="1" Text="ShortcutHook" Foreground="#EFEFEF" FontSize="22"
                   FontWeight="Bold" HorizontalAlignment="Center" Margin="0,12,0,0"/>

        <TextBlock Grid.Row="2" x:Name="VersionText" Foreground="#555555" FontSize="12"
                   HorizontalAlignment="Center" Margin="0,4,0,0"/>

        <Border Grid.Row="3" Background="#222222" Height="1" Margin="0,20,0,0"/>

        <TextBlock Grid.Row="4" Foreground="#666666" FontSize="12"
                   HorizontalAlignment="Center" Margin="0,18,0,0">
            <Run>by </Run><Run Foreground="#AAAAAA" FontWeight="SemiBold">veerabharath123</Run>
        </TextBlock>

        <TextBlock Grid.Row="5" HorizontalAlignment="Center" FontSize="12" Margin="0,8,0,0">
            <Hyperlink Foreground="#5B9CF6" TextDecorations="None"
                       RequestNavigate="GitHubLink_RequestNavigate"
                       NavigateUri="https://github.com/veera-bharath/ShortcutHook">
                github.com/veera-bharath/ShortcutHook
            </Hyperlink>
        </TextBlock>

        <Button Grid.Row="7" Content="Close" Style="{StaticResource GhostBtn}"
                Height="34" Width="90" HorizontalAlignment="Center"
                Click="CloseBtn_Click"/>
    </Grid>
</Window>
