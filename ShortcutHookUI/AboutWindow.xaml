<Window x:Class="ShortcutHookUI.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About ShortcutHook" Width="320" Height="260"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#111111" FontFamily="Segoe UI"
        Icon="pack://application:,,,/Assets/ShortcutHook.ico">
    <Grid Margin="28,22,28,22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Image Grid.Row="0" Source="pack://application:,,,/Assets/ShortcutHook.png"
               Width="48" Height="48" HorizontalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>

        <TextBlock Grid.Row="1" Text="ShortcutHook" Foreground="#EFEFEF" FontSize="20"
                   FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0"/>

        <TextBlock Grid.Row="2" x:Name="VersionText" Foreground="#555555" FontSize="12"
                   HorizontalAlignment="Center" Margin="0,4,0,0"/>

        <TextBlock Grid.Row="3" Foreground="#666666" FontSize="12"
                   HorizontalAlignment="Center" Margin="0,14,0,0">
            by <Run Foreground="#AAAAAA">veerabharath123</Run>
        </TextBlock>

        <TextBlock Grid.Row="4" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12">
            <Hyperlink x:Name="GitHubLink" Foreground="#5B9CF6" TextDecorations="None"
                       RequestNavigate="GitHubLink_RequestNavigate"
                       NavigateUri="https://github.com/veera-bharath/ShortcutHook">
                github.com/veera-bharath/ShortcutHook
            </Hyperlink>
        </TextBlock>

        <Button Grid.Row="5" Content="Close" Height="32" Width="80" HorizontalAlignment="Center"
                Background="Transparent" Foreground="#CCCCCC" BorderBrush="#2E2E2E"
                Click="CloseBtn_Click"/>
    </Grid>
</Window>
